# GitHub Configuration
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Anthropic Configuration
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Server Configuration
PORT=3000

# Review Trigger Mode: "auto" (PR events), "comment" (manual trigger), or "both" (default)
REVIEW_TRIGGER_MODE=both

# LogStash (CSV in `logStash/mm_yyyy.csv` after each completed review; legacy `mm_yyyy.json` is imported on first write if present)
# LOGSTASH_TIMEZONE=Asia/Bangkok
# LOGSTASH_BASELINE_SECONDS=1800
# LOGSTASH_DIR=logStash
# LOGSTASH_REQUESTER=NitiponArm
# LOGSTASH_CSV_AGENT=Claude Sonnet 4
